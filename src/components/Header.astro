---
import LeagueDecider from '../components/LeagueDecider.astro';
import '../styles/header.css';

const leagues = [
	"Premier League",
	"La Liga",
	"Serie A",
	"Bundesliga",
	"Ligue 1"
];
---

<header class="site-header">
	<div class="header-inner">
		<div class="title">FutBud</div>

		<div class="leagueDecider">

		{
			leagues.map((league) => (
				<LeagueDecider {league}/>
			))
		}

		<script>
			const buttons = document.querySelectorAll('.LD-wrapper');

			buttons.forEach((button) => {
				button.addEventListener('click', () => {
				buttons.forEach((btn) => btn.classList.remove('active'));
				button.classList.add('active');
				});
			});
		</script>

	
	</div>
		<div class="nav">
			<div class="explain">
				<p>Power & Luck</p>
				<p>Ranking?</p>
			</div>
			<div class="about">About Me</div>
		</div>
	</div>
</header>

