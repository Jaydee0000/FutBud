---
import '../styles/table.css';
import Leaderboard from '../components/Leaderboard.astro';

interface Props{
    LeagueName: string;
    teams: string[];
    logos: string[];
    teamStats: number[][];
    stats: string[];
}

const{
    LeagueName,
    teams,
    teamStats,
    logos,
    stats
} = Astro.props;
---


<div class="Table-wrapper">
    <div class="Table-header">
         <div class="Table-pl">
            <div class="Table-place">
                <p>#</p>
            </div>
            
            <div class="Table-league">
                <p>{LeagueName}</p>
            </div>
            
         </div>
        
        <div class="Table-statWrap">
            {
                stats.map((stat) => (
                    <div class="Table-statHead">
                        {stat}
                    </div>
                ))
            }
        </div>
    </div>

    <div class="Table-content">
        {
            teams.map((team, index) => (
                <Leaderboard
                team={team} 
                teamLogo={logos[index]}
                teamStats={teamStats[index]}
                />
            ))
        }
    </div>
</div>

 
