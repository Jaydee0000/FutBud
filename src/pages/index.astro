				[4, 90.2, 1.9, 1.1],
				[5, 90.0, 1.8, 1.2]
			]}
		/>

	</div>


	<div class="right-panel">
		<FGTable
			LeagueName="Premier League"
			teams={[
				"Arsenal",
				"Man City",
				"Man United",
				"Aston Villa",
