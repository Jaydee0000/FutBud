---
import Header from '../components/Header.astro';
import LeagueDD from '../components/LeagueDropDownCard.astro';
import League from '../components/LeagueUpcoming.astro';
import H2hExample from '../components/TeamStatCompare.astro';
import LeaderboardRanks from '../components/RatingLeaderBoard.astro';
import FGTable from '../components/Table.astro';
import Gamecard from '../components/teamsh2h.astro';
import '../styles/global.css';
import '../styles/content.css';

const leagues = [
	"Premier League",
	"La Liga",
	"Serie A",
	"Bundesliga",
	"Ligue 1"
];
---

<Header />

<main class="content">
	<div class="left-panel">
		<League/>
		<LeagueDD/>
	</div>

	<div class="middle-panel">
		<H2hExample
		title="Featured Game"
		competition="UEFA Champions League"
		team1="Arsenal"
		team2="Chelsea"
		team1P="80"
		team2P="80"
		team1L="80"
		team2L="80"
		team1Odd="80"
		team2Odd="80"
		team1HA="80"
		team2HA="80"
		team1RR="80"
		team2RR="80"
		/>

		<LeaderboardRanks
			header="Power Rankings"
			teams={["Liverpool", "Arsenal", "Man City", "Chelsea", "Manchester United"]}
			logos={["/manCity.png", "/manUnited.png", "/manCity.png", "/manUnited.png", "/manCity.png"]}
			stats={["P%", "XG", "GA"]}
			teamStats={[
				[1, 95.2, 2.4, 0.8],
