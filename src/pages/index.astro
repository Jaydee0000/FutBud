				[4, 90.2, 1.9, 1.1],
				[5, 90.0, 1.8, 1.2]
			]}
		/>

		<LeaderboardRanks
			header="Luck Rankings"
			teams={["Liverpool", "Arsenal", "Manchester City", "Chelsea", "Manchester United"]}
			logos={["/manCity.png", "/manUnited.png", "/manCity.png", "/manUnited.png", "/manCity.png"]}
